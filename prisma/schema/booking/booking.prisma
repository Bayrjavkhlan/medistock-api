model Booking {
  id String @id @default(uuid())

  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId String

  patientUser   User?   @relation("PatientBookings", fields: [patientUserId], references: [id])
  patientUserId String?

  patientName  String
  patientPhone String

  department  String
  doctorName  String?
  bookingTime DateTime

  status BookingStatus
  type   BookingType   @default(GENERAL)

  diagnosticTest   DiagnosticTest? @relation(fields: [diagnosticTestId], references: [id])
  diagnosticTestId String?

  diagnosticTimeSlot   DiagnosticTimeSlot? @relation(fields: [diagnosticTimeSlotId], references: [id])
  diagnosticTimeSlotId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
