# Backend runtime mode. Use "local" to disable helmet in local development.
NODE_ENV=local

# Backend HTTP port.
PORT=4000

# GraphQL endpoint path served by the Express/Apollo server.
GRAPHQL_PATH=/api/graphql

# Comma-separated list of frontend origins allowed by CORS.
CORS_DOMAIN=http://localhost:3000

# JWT signing secret for access and refresh tokens.
JWT_SECRET=change-me-local-dev-secret

# PostgreSQL connection string for local development.
# This repo's docker-compose exposes Postgres on localhost:5433.
DATABASE_URL=postgresql://medistock_user:123456@localhost:5433/medistock_db?schema=public

# Optional cookie domain. Leave blank for localhost so cookies are host-only.
COOKIE_DOMAIN=
